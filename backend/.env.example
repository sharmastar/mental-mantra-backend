# ─── Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/mental_mantra_db?schema=public"

# ─── JWT Secrets (REQUIRED - generate strong random values) ──────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In dev mode, these are auto-generated if left as placeholders.
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=your_csrf_secret_here

# ─── Google OAuth ─────────────────────────────────────────────────
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Firebase ─────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=mental-mantra-2024
# For Firebase Admin SDK:
# FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── AI / Gemini ─────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Must be set for AI features (chat, wellness coach, mood analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: Other AI Providers ─────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here
# GROQ_API_KEY=your_groq_api_key_here

# ─── Brevo (Email) ────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ─── CORS ─────────────────────────────────────────────────────────
# Comma-separated origins allowed. Use * for development.
ALLOWED_ORIGINS=*

# ─── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Hugging Face ─────────────────────────────────────────────────
HUGGING_FACE_TOKEN=your_huggingface_token_here

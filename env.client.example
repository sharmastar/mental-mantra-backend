# Compile-time Environment Variables for the Flutter Client
# This file must contain ONLY public configurations. 
# NO API KEYS or secrets should be placed here.

# Backend API base URL (override at build time)
# For production, set to your deployed backend domain (e.g., https://mental-mantra-backend.web.app)
BACKEND_URL=http://localhost:3000

# Google OAuth Client ID (from Google Cloud / Firebase console)
# GOOGLE_CLIENT_ID=your_google_client_id_here
